# CorePost preboot configuration for Debian initramfs-tools.
COREPOST_SERVER_URL="__SET_ME__"
COREPOST_DEVICE_ID="replace-me"
COREPOST_DEVICE_SECRET="replace-me"
COREPOST_UNLOCK_PROFILE="2fa"
COREPOST_USB_KEY_PATH="/dev/disk/by-label/COREPOST_USB"
COREPOST_NETWORK_IFACE="auto"
COREPOST_NETWORK_TIMEOUT_SECONDS="20"
COREPOST_NETWORK_FAILURE_POLICY="deny"
COREPOST_REQUEST_RETRIES="3"
COREPOST_REQUEST_RETRY_DELAY_SECONDS="2"
COREPOST_SERVER_CONNECT_TIMEOUT_SECONDS="5"
COREPOST_SERVER_MAX_TIME_SECONDS="20"
COREPOST_LUKS_DEVICE="/dev/corepost-preboot-demo-luks"
COREPOST_LUKS_NAME="corepost-demo-crypt"
